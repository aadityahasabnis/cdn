{
	"name": "cdn",
	"version": "1.0.0",
	"private": true,
	"description": "Cloudflare-based media hosting backend API",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"start": "wrangler dev",
		"types": "wrangler types",
		"typecheck": "tsc --noEmit",
		"db:init": "wrangler d1 execute media-db --file=schema.sql",
		"db:init:local": "wrangler d1 execute media-db --local --file=schema.sql",
		"db:query": "wrangler d1 execute media-db"
	},
	"dependencies": {
		"hono": "^4.6.20",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20240405.0",
		"@types/node": "^22.13.0",
		"typescript": "^5.9.3",
		"wrangler": "^4.71.0"
	}
}
